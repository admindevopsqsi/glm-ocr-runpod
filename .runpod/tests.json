{
    "tests": [
        {
            "name": "text_recognition_base64",
            "input": {
                "openai_route": "/v1/chat/completions",
                "openai_input": {
                    "model": "zai-org/GLM-OCR",
                    "max_tokens": 256,
                    "temperature": 0.01,
                    "messages": [
                        {
                            "role": "user",
                            "content": [
                                {
                                    "type": "image_url",
                                    "image_url": {
                                        "url": "data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAoAAAAKCAIAAAACUFjqAAAAEElEQVR4nGP4jxcwjEpjAwD6Hirkl4HYkQAAAABJRU5ErkJggg=="
                                    }
                                },
                                {
                                    "type": "text",
                                    "text": "Text Recognition:"
                                }
                            ]
                        }
                    ]
                }
            },
            "timeout": 900000
        }
    ],
    "config": {
        "gpuTypeId": "NVIDIA GeForce RTX 4090",
        "gpuCount": 1
    }
}
